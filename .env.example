# TALOS Protocol — Environment Variables
# Copy to .env and fill in values

# Deployer private key (TESTNET ONLY — never use mainnet key)
PRIVATE_KEY=

# Monad Testnet RPC (primary — all deploys here)
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Monad Mainnet RPC (fork tests ONLY — no deploy)
MONAD_MAINNET_RPC=https://rpc.monad.xyz

# Monadscan API key (for contract verification)
MONADSCAN_API_KEY=
